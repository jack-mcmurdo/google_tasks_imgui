{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug (GDB)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "GOOGLE_CLIENT_ID",
                    "value": "492917157691-lap1e9nte0gvq44t2712o9pmgvfvkofb.apps.googleusercontent.com"
                },
                {
                    "name": "GOOGLE_CLIENT_SECRET",
                    "value": "REDACTED"
                }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
